{
  "name": "task-manager",
  "tags": ["scope:server"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx watch src/main.ts",
        "cwd": "apps/task-manager"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx src/main.ts",
        "cwd": "apps/task-manager"
      }
    }
  }
}
