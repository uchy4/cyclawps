{
  "name": "kanban-board",
  "tags": ["scope:kanban"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite --port 4200",
        "cwd": "apps/kanban-board"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite build",
        "cwd": "apps/kanban-board"
      },
      "cache": true
    }
  }
}
