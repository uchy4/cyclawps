{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "task-manager",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "apps/task-manager/src/main.ts"],
      "port": 3001,
      "env": {
        "TASK_MANAGER_PORT": "3001"
      }
    },
    {
      "name": "dashboard",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd apps/dashboard && npx vite"],
      "port": 4000,
      "autoPort": true
    },
    {
      "name": "whisper-service",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd apps/whisper-service && source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 4002 --reload"],
      "port": 4002,
      "autoPort": false
    }
  ]
}
