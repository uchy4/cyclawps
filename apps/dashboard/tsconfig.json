{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/dashboard",
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../kanban-board/src/**/*.ts",
    "../kanban-board/src/**/*.tsx",
    "../chat-client/src/**/*.ts",
    "../chat-client/src/**/*.tsx",
    "../agent-configurator/src/**/*.ts",
    "../agent-configurator/src/**/*.tsx"
  ],
  "references": [
    { "path": "../../libs/shared" },
    { "path": "../kanban-board" },
    { "path": "../chat-client" },
    { "path": "../agent-configurator" }
  ]
}
