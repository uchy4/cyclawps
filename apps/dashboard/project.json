{
  "name": "dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "tags": ["scope:dashboard"],
  "implicitDependencies": ["task-manager", "whisper-service"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite --port 4000",
        "cwd": "apps/dashboard"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite build",
        "cwd": "apps/dashboard"
      },
      "cache": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npm exec nx run task-manager:serve",
          "npm exec nx run dashboard:serve",
          "npm exec nx run whisper-service:serve"
        ],
        "parallel": true,
        "env": {
          "NX_DAEMON": "false",
          "ANTHROPIC_API_KEY": ""
        }
      }
    },
    "kill-ports": {
      "executor": "nx:run-commands",
      "options": {
        "command": "for p in 3000 3001 4000 4001 4002 4200 4201 4202; do lsof -ti :$p 2>/dev/null; done | sort -u | xargs kill -9 2>/dev/null; echo 'All dev ports cleared'"
      }
    }
  }
}
