{
  "name": "dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "tags": ["scope:dashboard"],
  "implicitDependencies": ["task-manager", "whisper-service"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite --port 4000",
        "cwd": "apps/dashboard"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite build",
        "cwd": "apps/dashboard"
      },
      "cache": true
    }
  }
}
