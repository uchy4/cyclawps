{
  "name": "whisper-service",
  "projectType": "application",
  "sourceRoot": "apps/whisper-service",
  "tags": ["scope:server"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port ${WHISPER_PORT:-4002} --reload",
        "cwd": "apps/whisper-service"
      }
    },
    "setup": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt",
        "cwd": "apps/whisper-service"
      }
    }
  }
}
