{
  "name": "whisper-service",
  "projectType": "application",
  "sourceRoot": "apps/whisper-service",
  "tags": ["scope:server"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": ".venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 4002 --reload",
        "cwd": "apps/whisper-service"
      }
    },
    "setup": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt",
        "cwd": "apps/whisper-service"
      }
    }
  }
}
