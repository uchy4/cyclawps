# Default API key — used by all agents unless overridden per-agent
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Per-agent API key overrides (optional — falls back to ANTHROPIC_API_KEY)
# AGENT_PM_API_KEY=sk-ant-...
# AGENT_ARCHITECT_API_KEY=sk-ant-...
# AGENT_DEVELOPER_API_KEY=sk-ant-...
# AGENT_TESTER_API_KEY=sk-ant-...
# AGENT_GRUNT_API_KEY=sk-ant-...

# Per-agent model overrides (optional — defaults set in YAML seed files)
# PM=sonnet, Architect/Developer/Tester=opus, Grunt=haiku
# AGENT_PM_MODEL=claude-sonnet-4-6
# AGENT_ARCHITECT_MODEL=claude-opus-4-6
# AGENT_DEVELOPER_MODEL=claude-opus-4-6
# AGENT_TESTER_MODEL=claude-opus-4-6
# AGENT_GRUNT_MODEL=claude-haiku-4-5

# Per-agent max turns overrides (optional)
# AGENT_PM_MAX_TURNS=5
# AGENT_ARCHITECT_MAX_TURNS=10
# AGENT_DEVELOPER_MAX_TURNS=20
# AGENT_TESTER_MAX_TURNS=10
# AGENT_GRUNT_MAX_TURNS=8

# Server ports
TASK_MANAGER_PORT=3000
KANBAN_PORT=4200
CHAT_PORT=4201
CONFIGURATOR_PORT=4202

# Database
# DB_PATH=./data/cyclawps.db
