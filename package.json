{
  "name": "@agents-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "serve:server": "nx run task-manager:serve",
    "serve:kanban": "nx run kanban-board:serve",
    "serve:chat": "nx run chat-client:serve",
    "serve:configurator": "nx run agent-configurator:serve",
    "serve:dashboard": "nx run dashboard:serve",
    "start": "nx run-many --target=serve --projects=task-manager,dashboard --parallel",
    "start:all": "nx run-many --target=serve --all --parallel",
    "build": "nx run-many --target=build --all",
    "build:dashboard": "nx run dashboard:build",
    "start:desktop": "nx run-many --target=serve --projects=dashboard,desktop --parallel",
    "postinstall": "electron-builder install-app-deps",
    "nxe:build:frontend": "nx build dashboard",
    "nxe:build:backend": "nx build desktop",
    "nxe:serve:frontend": "nx serve dashboard",
    "nxe:serve:backend": "nx serve desktop",
    "nxe:test:frontend": "nx test dashboard",
    "nxe:test:backend": "nx test desktop",
    "nxe:package:app": "nx run desktop:make --prepackgeOnly",
    "nxe:make:app": "nx run desktop:make"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
