{
  "name": "@agents-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "NX_DAEMON=false nx run-many --target=serve --projects=task-manager,dashboard,whisper-service --parallel",
    "dev:server": "NX_DAEMON=false nx run task-manager:serve",
    "dev:ui": "NX_DAEMON=false nx run dashboard:serve",
    "dev:desktop": "NX_DAEMON=false nx run-many --target=serve --projects=dashboard,desktop --parallel",
    "build": "nx run-many --target=build --all",
    "desktop:make": "nx run desktop:make",
    "kill-ports": "for p in 3000 3001 4000 4001 4002 4200 4201 4202; do lsof -ti :$p 2>/dev/null; done | sort -u | xargs kill -9 2>/dev/null; echo 'All dev ports cleared'",
    "postinstall": "electron-builder install-app-deps"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "^22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/node": "^22.6.1",
    "@nx/react": "^22.6.1",
    "@nx/vite": "^22.6.1",
    "@nx/web": "^22.6.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^35.7.5",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nx": "22.6.1",
    "nx-electron": "^22.0.0",
    "prettier": "^2.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.0.0",
    "webpack-node-externals": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
