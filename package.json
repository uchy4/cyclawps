    "@types/node": "20.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^34.5.6",
